{
  "name": "rest-express-server",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development tsx server/index.ts",
    "dev:client": "npm run dev --prefix client",
    "build:client": "npm ci --prefix client && npm run build --prefix client",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && mv dist/client dist/frontend",
    "build": "npm run build:client && npm run build:server",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "seed": "tsx -r dotenv/config server/seed.ts",
    "seed-admin": "tsx -r dotenv/config server/seed-admin.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/multer": "^2.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "memorystore": "^1.6.7",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.18.0",
    "redis": "^4.7.1",
    "vite-tsconfig-paths": "^6.1.1",
    "wouter": "^3.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "20.16.11",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.0",
    "nanoid": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.20"
  }
}
